{
  "version": 2,
  "framework": "python",
  "builds": [
    {
      "src": "messenger_server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "messenger_server.py"
    },
    {
      "src": "/(.*)",
      "dest": "messenger_server.py"
    }
  ]
}
