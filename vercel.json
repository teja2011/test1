{
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "index.py"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|gif|svg|ico|css|js|map))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ],
  "outputDirectory": "public"
}
