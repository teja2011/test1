{
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/migrate.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/Jetesk.png",
      "dest": "/index.py"
    },
    {
      "src": "/sw.js",
      "dest": "/index.py"
    },
    {
      "src": "/manifest.json",
      "dest": "/index.py"
    },
    {
      "src": "/virtual-scroll.js",
      "dest": "/index.py"
    },
    {
      "src": "/app.js",
      "dest": "/index.py"
    },
    {
      "src": "/test-registration.html",
      "dest": "/index.py"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/api/migrate",
      "dest": "/api/migrate.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.py"
    }
  ]
}
